{
  "name": "info303-better-stop",
  "version": "1.0.0",
  "description": "INFO 303 multimodal remix artifact for a Better Stop wayfinding prototype.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.170.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10"
  },
  "private": true
}
